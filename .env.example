# ── LLM Keys (optional — at least one needed for cloud AI responses) ────────
ANTHROPIC_API_KEY=sk-ant-...          # Preferred cloud LLM — uses claude-sonnet-4
OPENAI_API_KEY=sk-...                 # Fallback cloud LLM — uses gpt-4o-mini

# ── Local / Offline LLM (no internet required) ──────────────────────────────
# Download any GGUF model and point this at the file.
# Recommended: Mistral-7B-Instruct-v0.2.Q4_K_M.gguf (~4 GB)
#   https://huggingface.co/TheBloke/Mistral-7B-Instruct-v0.2-GGUF
LOCAL_LLM_ENABLED=1
LOCAL_LLM_MODEL_PATH=models/railman-chat.gguf
LOCAL_LLM_N_CTX=4096                 # Context window (tokens)
LOCAL_LLM_THREADS=6                  # CPU threads for inference
LOCAL_LLM_GPU_LAYERS=0               # Set >0 to offload layers to GPU (CUDA/Metal)
LOCAL_LLM_MAX_TOKENS=320             # Max tokens per response
LOCAL_LLM_TEMPERATURE=0.2            # Lower = more deterministic
LOCAL_LLM_TOP_P=0.9

# ── Provider order (comma-separated) ────────────────────────────────────────
# Controls which LLM is tried first. Set to "local" for fully offline mode.
RAILMAN_LLM_PROVIDER_ORDER=local,anthropic,openai,rule_based
# For strict offline operation (no cloud calls at all):
# RAILMAN_LLM_PROVIDER_ORDER=local,rule_based
# RAILMAN_LOCAL_ONLY=1

# ── MongoDB — Trains Database ────────────────────────────────────────────────
# Stores: stations, trains, live_positions
# Cloud: create a FREE M0 cluster on cloud.mongodb.com
MONGODB_TRAINS_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_TRAINS_DB=railman_trains
# Local MongoDB (offline): install https://www.mongodb.com/try/download/community
# MONGODB_TRAINS_URI=mongodb://localhost:27017
# MONGODB_TRAINS_DB=railman_trains

# ── MongoDB — Chat/User Database ────────────────────────────────────────────
# Stores: chat_memory, logs, recommendations, feedback, users, rate_limits
MONGODB_CHAT_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_CHAT_DB=railman_chat
# Local MongoDB (offline):
# MONGODB_CHAT_URI=mongodb://localhost:27017
# MONGODB_CHAT_DB=railman_chat

# ── Fallback (one URI for both DBs — dev shortcut) ──────────────────────────
# MONGODB_URI=mongodb://localhost:27017

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000
