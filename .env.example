# ── LLM Keys (at least one required for AI responses) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Preferred — uses claude-sonnet-4
OPENAI_API_KEY=sk-...                 # Fallback — uses gpt-4o-mini

# ── MongoDB — Trains Database ───────────────────────────────────────────────
# Stores: stations, trains, live_positions
# Create a FREE M0 cluster on cloud.mongodb.com and paste the URI here.
MONGODB_TRAINS_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_TRAINS_DB=railman_trains

# ── MongoDB — Chat/User Database ────────────────────────────────────────────
# Stores: chat_memory, logs, recommendations, feedback, users, rate_limits
# Can be a separate cluster/database from the trains DB, or the same cluster
# with a different database name. Using two separate databases is recommended.
MONGODB_CHAT_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_CHAT_DB=railman_chat

# ── Fallback (used if MONGODB_TRAINS_URI / MONGODB_CHAT_URI are not set) ───
# Set this alone to use one connection string for both DBs (dev shortcut).
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000
